# Cursor Bridge 配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# [必填] Silk 后端地址
BRIDGE_SERVER=localhost:8006

# [必填] Bridge Token（在 Silk 设置页生成；与 cc_bridge / codex_bridge 共用同一个 token）
BRIDGE_TOKEN=your-token-here

# [可选] Cursor 默认工作目录（默认为当前目录）
# BRIDGE_WORKING_DIR=/workspace/your-project

# [可选] 日志级别: DEBUG / INFO / WARNING / ERROR（默认 INFO）
# BRIDGE_LOG_LEVEL=INFO

# [推荐] 在仓库外创建的 venv 里的 python3 绝对路径
# BRIDGE_PYTHON=/path/to/your-venv/bin/python3

# [可选] WSS 自签证书时设为 1（bridge.sh 会加 --tls-insecure；勿在生产公网长期开启）
# BRIDGE_TLS_INSECURE=1

# ----- Cursor 专属选项 -----

# [可选] Cursor agent CLI 可执行文件路径（不设则自动探测 PATH 和常见安装位置）
# CURSOR_AGENT_PATH=/usr/local/bin/agent

# [可选] 空闲回收超时秒数（默认 1800 = 30 分钟；子进程闲置超过此时间自动回收）
# CURSOR_IDLE_TIMEOUT=1800
