# ============================================================
# Silk_v2 环境变量示例
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env：  cp .env.example .env
# 2. 在 .env 中填入真实的 API Key 和配置（不要提交 .env 到版本库）
# 3. 启动前加载：source .env  或由 silk.sh 自动加载
# 4. 构建 Android/Desktop/Web 前端时，Gradle 会读取 .env 中的 BACKEND_HOST 等注入到应用
# ============================================================

# ----- 后端/公网地址（前端连接、nginx、邀请链接等统一使用） -----
# 公网 IP 或域名，用于 Android/Desktop 客户端、邀请文案、nginx server_name 等
BACKEND_HOST=your.server.ip.or.domain
# 后端 HTTP 端口（浏览器/APK/邀请链接使用的公网端口，默认 8006）
BACKEND_HTTP_PORT=
# 后端进程实际监听端口（可选）。仅当前面有反向代理（nginx 等）把公网端口转发到本机另一端口时才与 BACKEND_HTTP_PORT 不同。
# 无代理时请勿同时写两个不同端口，否则易出现「公网端口仍是旧后端、INTERNAL 才是新代码」的导出/接口不一致；更简单做法是省略本行，让进程直接监听 BACKEND_HTTP_PORT。
# BACKEND_INTERNAL_PORT=18003
# 工作流持久化目录（强烈建议设为仓库外固定目录，防止 git 操作影响运行时数据）
# SILK_WORKFLOW_DIR=/home/your_user/.silk-data/workflows
# 对外访问协议，推荐 https（若未设置 BACKEND_BASE_URL 时用于自动拼接）
# BACKEND_SCHEME=https
# 后端进程监听地址，默认 0.0.0.0 表示所有网卡
# SERVER_HOST=0.0.0.0
# 若需直接写完整地址可设此项，否则由 BACKEND_HOST + BACKEND_HTTP_PORT 自动得到
# BACKEND_BASE_URL=http://your.server.ip:8006
# Web 前端公网地址（可选，默认用 BACKEND_BASE_URL 的端口改为 8001，供 /api/public-config 返回）
# BACKEND_WEB_APP_BASE_URL=http://your.server.ip:8001

# ----- AI 服务 (Anthropic Claude API — 新主线) -----
# 必填：Anthropic API Key（从 https://console.anthropic.com 获取）
ANTHROPIC_API_KEY=

# 可选：Anthropic API 基础 URL，默认 https://api.anthropic.com（自建代理时修改）
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# 可选：Claude 模型名称，默认 claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ----- AI 服务 (OpenAI 兼容接口 — 已弃用，请换用 ANTHROPIC_*) -----
# OpenAI API Key（旧 @silk 用，已由 Claude 替代）
# OPENAI_API_KEY=
# AI API 基础 URL
# API_BASE_URL=
# 模型名称
# AI_MODEL=

# 可选：后端请求 AI API 的超时（毫秒），默认 300000（5 分钟）
# AI_HTTP_TIMEOUT_MS=300000

# ----- 文件预处理管线（PDF/图片自动提取为文本，供 Claude CLI 读取） -----
# 是否启用文件预处理（默认 true）
# SILK_FILE_PREPROCESS_ENABLED=true
# 是否启用 Vision API 为图片生成描述（需 ANTHROPIC_API_KEY，默认 true）
# SILK_VISION_ENABLED=true
# Vision 描述使用的模型（推荐 haiku：快速便宜）
# SILK_VISION_MODEL=claude-3-5-haiku-20241022
# Tesseract OCR 语言（需系统安装 tesseract：brew install tesseract tesseract-lang）
# SILK_OCR_LANGUAGES=eng+chi_sim

# ----- 向量库 Weaviate（已弃用：Claude 200K context + grep 替代） -----
# WEAVIATE_URL=

# ----- 外部搜索（已弃用：Claude 原生 web_search 替代） -----
# SEARXNG_URL=http://localhost:8080
# SERPAPI_KEY=
# BRAVE_API_KEY=
# BING_API_KEY=
# ENABLE_EXTERNAL_SEARCH=true

# 可选：单条 tool 消息写入大模型的最大字符数，默认 10000
# MAX_TOOL_MESSAGE_CHARS=10000

# ----- 工具与功能开关 -----
# 可选：是否启用模型工具调用，默认 true
# ENABLE_MODEL_TOOLS=true

# 可选：启用的工具列表，逗号分隔
# TOOLS_ENABLED=file_search,web_search,code_execution,browser
# ----- AutoCLI 集成 (nashsu/AutoCLI) -----
# 是否启用 AutoCLI 工具（从 55+ 网站获取结构化数据），默认 false
# AUTOCLI_ENABLED=true
# autocli 二进制路径，默认 "autocli"（需在 PATH 中）
# AUTOCLI_PATH=autocli
# 执行超时（秒），默认 60
# AUTOCLI_TIMEOUT=60

# ----- Claude Code 集成 -----
# claude CLI 路径，默认 "claude"（需在 PATH 中）
# CLAUDE_CODE_PATH=claude

# 默认工作目录，默认为后端进程工作目录
# CLAUDE_CODE_DEFAULT_DIR=/workspace

# 单次执行最大轮次，默认 100
# CLAUDE_CODE_MAX_TURNS=100

# 单次执行超时秒数，默认 36000（10小时）
# CLAUDE_CODE_TIMEOUT=36000

# 单次输出最大字符数（防止刷屏），默认 30000
# CLAUDE_CODE_MAX_OUTPUT_CHARS=30000

# ----- ASR 语音识别（vLLM / mlx_audio 等 OpenAI 兼容） -----
# 本地 ASR 服务地址（示例：vllm serve ... 或 mlx_audio.server --port 8100）
# ASR_VLLM_URL=http://localhost:8100
# ASR 模型名称（与服务端一致）
# ASR_MODEL=Qwen/Qwen3-ASR-1.7B
# 将 Web/M4A 等转为 16kHz WAV 再转发（mlx_audio 使用 miniaudio，常不支持 WebM；需本机安装 ffmpeg）
# ASR_TRANSCODE_TO_WAV=true
# ASR_FFMPEG_PATH=ffmpeg

# ----- Audio Duplex（MiniCPM-o 全双工语音对话） -----
# 全双工语音对话 WebSocket 服务地址（默认 http://localhost:8006）
# AUDIO_DUPLEX_URL=http://localhost:22700  # 直连 Worker；若用 Gateway 则为 http://localhost:8006
