<configuration>
    <variable name="LOG_LEVEL" value="${log.level:-INFO}"/>

    <!-- 控制台 appender：简洁格式 -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{20} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 文件 appender：详细格式 + 按日期和大小滚动 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/silk-backend.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/silk-backend.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <root level="${LOG_LEVEL}">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>

    <logger name="io.ktor" level="INFO"/>
    <logger name="com.silk" level="${LOG_LEVEL}"/>
    <logger name="com.silk.backend.ai" level="${LOG_LEVEL}"/>

    <!-- Silk Agent IO 日志：prompt/response 单独写入 logs/silk-agent-io.log，不混入主日志 -->
    <appender name="AGENT_IO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/silk-agent-io.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/silk-agent-io.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 开启后 prompt/response 写入 logs/silk-agent-io.log，调试完注释掉即可 -->
    <!-- <logger name="com.silk.backend.ai.DirectModelAgent" level="DEBUG" additivity="false">
        <appender-ref ref="AGENT_IO"/>
    </logger> -->
</configuration>
