# CC Bridge 配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# [必填] Silk 后端地址
BRIDGE_SERVER=localhost:8006

# [必填] Bridge Token（在 Silk 设置页生成）
BRIDGE_TOKEN=your-token-here

# [可选] Claude CLI 默认工作目录（默认为当前目录）
# BRIDGE_WORKING_DIR=/workspace/your-project

# [可选] 日志级别: DEBUG / INFO / WARNING / ERROR（默认 INFO）
# BRIDGE_LOG_LEVEL=INFO

# [推荐] 在仓库外创建的 venv 里的 python3 绝对路径（避免在 silk 目录下放 .venv）
# BRIDGE_PYTHON=/path/to/your-venv/bin/python3

# [可选] WSS 使用自签证书时设为 1（bridge.sh 会加 --tls-insecure；勿在生产公网长期开启）
# BRIDGE_TLS_INSECURE=1

# ----- Claude Code 走 DeepSeek（Anthropic 兼容端点）-----
# 子进程 claude 继承 Python 环境；此处必须用 export，否则 bridge.sh 启动的进程收不到。
# 文档: https://api-docs.deepseek.com/guides/coding_agents
# export ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# export ANTHROPIC_AUTH_TOKEN=<DeepSeek API Key>
# export ANTHROPIC_MODEL=deepseek-v4-flash
# export ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro
# export ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro
# export ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
# export CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
# export CLAUDE_CODE_EFFORT_LEVEL=max
